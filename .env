# ══════════════════════════════════════════════════════════════════════════════
# 🤖 Modern Guide Bot - متغيرات البيئة
# ══════════════════════════════════════════════════════════════════════════════

# ─── 🔧 إعدادات التطبيق ──────────────────────────────────────────────────────
ENV=development                          # development, staging, production
DEBUG=True                               # تفعيل وضع التصحيح
LOG_LEVEL=INFO                           # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ─── 🤖 Telegram Bot ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username_here      # اسم البوت (بدون @)
CHANNEL_ID=-100xxxxxxxxxx                # قناة النشر التلقائي (تبدأ بـ -100)
ADMIN_ID=xxxxxxxxxx                      # معرّف المدير (بدون -)
ADMIN_USERNAMES=admin1,admin2            # أسماء المسؤولين (مفصولة بفواصل)

# ─── 🧠 خدمات الذكاء الاصطناعي ──────────────────────────────────────────────
# Google Gemini (الأساسي)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro                  # أو gemini-pro-vision
GEMINI_MAX_TOKENS=2048

# OpenAI (احتياطي)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo               # أو gpt-4
OPENAI_MAX_TOKENS=2048

# Groq (احتياطي ثاني - سريع جداً)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=mixtral-8x7b-32768

# ─── 🔍 خدمات البحث ──────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_MAX_RESULTS=5
SEARCH_TIMEOUT=30                        # ثواني

# ─── 📄 إنشاء المستندات ─────────────────────────────────────────────────────
# مسارات التخزين
DOCUMENTS_PATH=./documents                # مجلد حفظ المستندات
TEMPLATES_PATH=./templates                # مجلد القوالب
UPLOADS_PATH=./uploads                    # مجلد الرفع

# أنواع المستندات المدعومة
PDF_ENABLED=True
DOCX_ENABLED=True
PPTX_ENABLED=True
XLSX_ENABLED=True

# إعدادات المستندات
PDF_MAX_SIZE=10485760                    # 10 MB بالبايت
DOCUMENT_QUALITY=high                    # low, medium, high

# ─── 💾 قاعدة البيانات ──────────────────────────────────────────────────────
# SQLite (للتطوير المحلي)
DATABASE_TYPE=sqlite
DATABASE_PATH=./data/bot.db

# PostgreSQL (للإنتاج)
# DATABASE_TYPE=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/modern_guide_bot
# DB_POOL_SIZE=20
# DB_ECHO=False

# SQLAlchemy
SQLALCHEMY_TRACK_MODIFICATIONS=False

# ─── 👥 نظام المستخدمين ────────────────────────────────────────────────────
MAX_REQUESTS_PER_HOUR=100                # حد أقصى للطلبات في الساعة
MAX_DOCUMENTS_PER_DAY=50                 # حد أقصى للمستندات يومياً
FREE_TIER_LIMIT=10                       # حد مجاني يومي
PREMIUM_TIER_LIMIT=1000                  # حد مميز يومي

# ─── 🎛️ لوحة التحكم ────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=your_dashboard_password_here  # كلمة مرور لوحة التحكم
SESSION_SECRET=a_very_long_random_secret_string_here_change_me  # مفتاح الجلسة
DASHBOARD_PORT=5000                      # منفذ لوحة التحكم
DASHBOARD_HOST=0.0.0.0                   # العنوان
JWT_SECRET_KEY=your_jwt_secret_key_here  # مفتاح JWT للـ API

# ─── 📧 البريد الإلكتروني (اختياري) ─────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here     # كلمة مرور التطبيق (ليس كلمة المرور الأساسية)
SENDER_EMAIL=your_email@gmail.com

# ─── 🔐 GitHub و Backup ──────────────────────────────────────────────────────
GH_TOKEN=your_github_pat_here
GITHUB_REPO=hocinmaghnaoui-HM/modern-guide-bot
BACKUP_ENABLED=True
BACKUP_INTERVAL=86400                    # يومي (بالثواني)

# ─── 📊 التحليلات (اختياري) ────────────────────────────────────────────────
ANALYTICS_ENABLED=True
SENTRY_DSN=                              # لتتبع الأخطاء (اختياري)

# ─── 🔗 الروابط الخارجية ────────────────────────────────────────────────────
WEBHOOK_URL=                             # رابط webhook (إن استخدمت)
WEBHOOK_SECRET=                          # سر webhook

# ─── ⏱️ الجدولة (Scheduling) ────────────────────────────────────────────────
SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=UTC                   # أو Asia/Riyadh للمملكة العربية السعودية

# ─── 🔌 APIs خارجية إضافية ─────────────────────────────────────────────────
HUGGINGFACE_API_KEY=                     # لنماذج HuggingFace (اختياري)
ANTHROPIC_API_KEY=                       # Claude API (اختياري)

# ─── 📱 إعدادات Telegram المتقدمة ───────────────────────────────────────────
BOT_WEBHOOK=False                        # True إذا استخدمت webhook
BOT_TIMEOUT=30                           # ثواني
BOT_REQUEST_TIMEOUT=5                    # ثواني

# ─── 🎨 إعدادات التصميم ────────────────────────────────────────────────────
LANGUAGE=ar                              # ar, en
THEME=dark                               # light, dark
BOT_VERSION=1.0.0

# ═══════════════════════════════════════════════════════════════════════════════
